---
import BaseLayout from "../layouts/BaseLayout.astro";

const streams = [
  {
    venue: "四樓國際會議廳",
    icon: "🏛️",
    videoId: "9LjYPj7uQcM",
    watchUrl: "https://www.youtube.com/watch?v=9LjYPj7uQcM",
  },
  {
    venue: "二樓展演廳",
    icon: "🎭",
    videoId: "ZfjwgdpwSyo",
    watchUrl: "https://youtube.com/live/ZfjwgdpwSyo?feature=share",
  },
];
---

<BaseLayout title="直播｜Sparkle">
  <section class="page-header fade-up">
    <h1 class="section-title">線上直播</h1>
    <p class="section-sub">即時觀看 Sparkle 成果發表會</p>
  </section>

  <div class="streams">
    {streams.map((s) => (
      <section class="stream fade-up">
        <div class="stream-header">
          <span class="stream-icon">{s.icon}</span>
          <h2 class="stream-title">{s.venue}</h2>
          {s.watchUrl && (
            <a class="stream-link" href={s.watchUrl} target="_blank" rel="noopener">
              在 YouTube 開啟 ↗
            </a>
          )}
        </div>
        {s.videoId ? (
          <div class="video-wrap">
            <iframe
              src={`https://www.youtube.com/embed/${s.videoId}?rel=0`}
              title={`${s.venue} 直播`}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            ></iframe>
          </div>
        ) : (
          <div class="placeholder">
            <div class="placeholder-icon">📺</div>
            <p>直播連結將於發表會當天提供</p>
          </div>
        )}
      </section>
    ))}
  </div>

  <style>
    .page-header { padding: 20px 0 8px; }

    .streams {
      display: grid;
      gap: 32px;
    }

    .stream-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
      flex-wrap: wrap;
    }
    .stream-icon { font-size: 26px; }
    .stream-title {
      font-size: 20px;
      font-weight: 700;
      flex: 1;
    }
    .stream-link {
      font-size: 13px;
      font-weight: 600;
      color: var(--accent);
      padding: 6px 12px;
      border-radius: 999px;
      border: 1px solid var(--border);
      transition: all var(--transition);
    }
    .stream-link:hover {
      background: var(--accent-bg);
      border-color: var(--accent-light);
    }

    .video-wrap {
      position: relative;
      width: 100%;
      padding-top: 56.25%;
      border-radius: var(--radius-lg);
      overflow: hidden;
      border: 1px solid var(--border);
      background: #000;
      box-shadow: var(--shadow);
    }
    .video-wrap iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }

    .placeholder {
      text-align: center;
      padding: 60px 24px;
      border: 2px dashed var(--border);
      border-radius: var(--radius-lg);
      background: var(--gradient-subtle);
      color: var(--muted);
    }
    .placeholder-icon {
      font-size: 48px;
      margin-bottom: 12px;
    }
    .placeholder p { font-size: 15px; font-weight: 500; }
  </style>
</BaseLayout>
