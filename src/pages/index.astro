---
import BaseLayout from "../layouts/BaseLayout.astro";
const BASE = import.meta.env.BASE_URL;
---

<BaseLayout title="Sparkle｜成果發表">
  <!-- Hero with animated mesh gradient -->
  <section class="hero">
    <div class="hero-bg">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
    </div>
    <canvas id="sparkle-canvas"></canvas>
    <div class="hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        2026 成果發表
      </div>
      <h1 class="hero-title">
        <span class="gradient-text">Sparkle</span>
        <br />
        <span class="title-line2">成果發表</span>
      </h1>
      <p class="hero-desc">
        2026/5/18&emsp;臺北市立建國高級中學&emsp;自由入場
      </p>
      <div class="hero-actions">
        <a class="hero-btn hero-btn-primary" href={`${BASE}projects/`}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          看專題
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
        <a class="hero-btn hero-btn-glass" href={`${BASE}schedule/`}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          看流程
        </a>
      </div>
    </div>
  </section>

  <!-- Stats with animated counters -->
  <section class="stats fade-up">
    <div class="stat-item">
      <div class="stat-num" data-target="29">0</div>
      <div class="stat-label">專題數量</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <div class="stat-num" data-target="6">0</div>
      <div class="stat-label">學科領域</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <div class="stat-num" data-target="40">0</div>
      <div class="stat-label">參與人數</div>
    </div>
  </section>

  <!-- Highlights with glassmorphism -->
  <section class="highlights fade-up">
    <h2 class="section-title">精選亮點</h2>
    <p class="section-sub">探索各領域同學的精彩研究成果</p>
    <div class="highlight-grid">
      <div class="glass-card" style="--delay: 0s">
        <div class="glass-card-glow"></div>
        <div class="glass-icon">🔬</div>
        <h3>跨領域研究</h3>
        <p class="muted">涵蓋數學、物理、化學、生物、資訊、地科六大領域的專題研究</p>
        <a class="card-link" href={`${BASE}projects/`}>
          探索專題
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </div>
      <div class="glass-card" style="--delay: 0.1s">
        <div class="glass-card-glow"></div>
        <div class="glass-icon">🎬</div>
        <h3>精彩影片</h3>
        <p class="muted">由影片組精心拍攝剪輯，記錄同學們的研究歷程與成果</p>
        <a class="card-link" href={`${BASE}about/`}>
          了解更多
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </div>
      <div class="glass-card" style="--delay: 0.2s">
        <div class="glass-card-glow"></div>
        <div class="glass-icon">🎵</div>
        <h3>原創音樂</h3>
        <p class="muted">音樂組原創作曲、編曲、作詞，為發表會增添獨特氛圍</p>
        <a class="card-link" href={`${BASE}about/`}>
          了解更多
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Category showcase -->
  <section class="categories fade-up">
    <h2 class="section-title">六大領域</h2>
    <p class="section-sub">點擊任一領域，直接查看相關專題</p>
    <div class="cat-grid">
      <a class="cat-pill" href={`${BASE}projects/?cat=數學`} style="--c: #7c3aed">
        <span class="cat-emoji">📐</span>
        <span>數學</span>
        <span class="cat-count">3</span>
      </a>
      <a class="cat-pill" href={`${BASE}projects/?cat=物理`} style="--c: #2563eb">
        <span class="cat-emoji">⚡</span>
        <span>物理</span>
        <span class="cat-count">6</span>
      </a>
      <a class="cat-pill" href={`${BASE}projects/?cat=化學`} style="--c: #dc2626">
        <span class="cat-emoji">🧪</span>
        <span>化學</span>
        <span class="cat-count">7</span>
      </a>
      <a class="cat-pill" href={`${BASE}projects/?cat=生物`} style="--c: #16a34a">
        <span class="cat-emoji">🧬</span>
        <span>生物</span>
        <span class="cat-count">6</span>
      </a>
      <a class="cat-pill" href={`${BASE}projects/?cat=資訊`} style="--c: #0891b2">
        <span class="cat-emoji">💻</span>
        <span>資訊</span>
        <span class="cat-count">6</span>
      </a>
      <a class="cat-pill" href={`${BASE}projects/?cat=地科`} style="--c: #d97706">
        <span class="cat-emoji">🌍</span>
        <span>地科</span>
        <span class="cat-count">1</span>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section fade-up">
    <div class="cta-card">
      <div class="cta-glow"></div>
      <h2>準備好探索了嗎？</h2>
      <p class="muted">瀏覽所有專題，發現同學們的研究成果</p>
      <div class="cta-actions">
        <a class="hero-btn hero-btn-primary" href={`${BASE}projects/`}>
          瀏覽全部專題
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
        <a class="hero-btn hero-btn-glass" href={`${BASE}about/`}>了解更多</a>
      </div>
    </div>
  </section>

  <style>
    /* ── Hero ── */
    .hero {
      position: relative;
      padding: 80px 0 60px;
      overflow: hidden;
      text-align: center;
    }

    .hero-bg {
      position: absolute;
      inset: -50%;
      z-index: 0;
      filter: blur(80px);
      opacity: 0.5;
    }
    .blob {
      position: absolute;
      border-radius: 50%;
    }
    .blob-1 {
      width: 400px; height: 400px;
      background: rgba(124,58,237,0.35);
      top: 10%; left: 20%;
      animation: float1 8s ease-in-out infinite;
    }
    .blob-2 {
      width: 350px; height: 350px;
      background: rgba(236,72,153,0.3);
      top: 30%; right: 15%;
      animation: float2 10s ease-in-out infinite;
    }
    .blob-3 {
      width: 300px; height: 300px;
      background: rgba(245,158,11,0.25);
      bottom: 10%; left: 40%;
      animation: float3 12s ease-in-out infinite;
    }

    @keyframes float1 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(30px, -40px) scale(1.05); }
      66% { transform: translate(-20px, 20px) scale(0.95); }
    }
    @keyframes float2 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(-40px, 30px) scale(1.08); }
      66% { transform: translate(25px, -25px) scale(0.92); }
    }
    @keyframes float3 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(35px, 25px) scale(1.04); }
      66% { transform: translate(-30px, -35px) scale(0.96); }
    }

    #sparkle-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
    }

    .hero-content { position: relative; z-index: 2; }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 18px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 600;
      color: var(--accent);
      background: rgba(124,58,237,0.08);
      border: 1px solid rgba(124,58,237,0.15);
      margin-bottom: 24px;
      backdrop-filter: blur(10px);
      animation: fadeInDown 0.8s ease both;
    }
    .badge-dot {
      width: 8px; height: 8px;
      background: var(--accent);
      border-radius: 50%;
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.8); }
    }

    .hero-title {
      font-size: clamp(44px, 9vw, 80px);
      font-weight: 900;
      line-height: 1.08;
      letter-spacing: -0.04em;
      margin-bottom: 20px;
      animation: fadeInUp 0.8s ease 0.1s both;
    }
    .title-line2 {
      display: inline-block;
      animation: fadeInUp 0.8s ease 0.2s both;
    }
    .gradient-text {
      background: var(--gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      background-size: 200% 200%;
      animation: gradientShift 4s ease infinite;
    }
    @keyframes gradientShift {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }

    .hero-desc {
      font-size: 16px;
      color: var(--muted);
      margin-bottom: 32px;
      animation: fadeInUp 0.8s ease 0.3s both;
    }
    .hero-actions {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
      animation: fadeInUp 0.8s ease 0.4s both;
    }

    /* Hero buttons */
    .hero-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 28px;
      border-radius: 14px;
      font-size: 15px;
      font-weight: 600;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      text-decoration: none;
    }
    .hero-btn-primary {
      background: var(--accent);
      color: #fff;
      box-shadow: 0 4px 16px rgba(124,58,237,0.3), inset 0 1px 0 rgba(255,255,255,0.15);
    }
    .hero-btn-primary:hover {
      background: #6d28d9;
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(124,58,237,0.4), inset 0 1px 0 rgba(255,255,255,0.15);
    }
    .hero-btn-glass {
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(0,0,0,0.08);
      color: var(--text);
    }
    .hero-btn-glass:hover {
      background: rgba(255,255,255,0.9);
      transform: translateY(-2px);
      box-shadow: var(--shadow);
    }

    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeInDown {
      from { opacity: 0; transform: translateY(-12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ── Stats ── */
    .stats {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 40px;
      padding: 44px 0;
      margin: 32px 0;
      background: var(--surface);
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
    }
    .stat-item { text-align: center; }
    .stat-num {
      font-size: 40px;
      font-weight: 900;
      letter-spacing: -0.03em;
      background: var(--gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .stat-num::after { content: '+'; }
    .stat-label { font-size: 13px; color: var(--muted); margin-top: 2px; font-weight: 500; }
    .stat-divider {
      width: 1px;
      height: 40px;
      background: var(--border);
    }
    @media (max-width: 520px) {
      .stats { gap: 20px; padding: 32px 20px; }
      .stat-num { font-size: 30px; }
      .stat-divider { height: 30px; }
    }

    /* ── Highlight glass cards ── */
    .highlights { padding: 48px 0; }
    .highlight-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    @media (max-width: 860px) { .highlight-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 520px) { .highlight-grid { grid-template-columns: 1fr; } }

    .glass-card {
      position: relative;
      border: 1px solid rgba(124,58,237,0.1);
      border-radius: var(--radius-lg);
      padding: 28px;
      background: rgba(255,255,255,0.8);
      backdrop-filter: blur(8px);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      overflow: hidden;
      animation: fadeInUp 0.6s ease calc(var(--delay)) both;
    }
    .glass-card-glow {
      position: absolute;
      top: -40px; right: -40px;
      width: 120px; height: 120px;
      border-radius: 50%;
      background: var(--gradient);
      opacity: 0;
      filter: blur(40px);
      transition: opacity 0.4s;
      pointer-events: none;
    }
    .glass-card:hover {
      border-color: rgba(124,58,237,0.2);
      box-shadow: 0 8px 32px rgba(124,58,237,0.1);
      transform: translateY(-6px);
    }
    .glass-card:hover .glass-card-glow { opacity: 0.15; }

    .glass-icon {
      font-size: 28px;
      width: 52px; height: 52px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      background: var(--gradient-subtle);
      border: 1px solid rgba(124,58,237,0.08);
      margin-bottom: 16px;
    }
    .glass-card h3 {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .glass-card p { font-size: 14px; line-height: 1.7; }

    .card-link {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      margin-top: 16px;
      font-size: 13px;
      font-weight: 600;
      color: var(--accent);
      transition: gap 0.3s ease;
    }
    .card-link:hover { gap: 8px; }

    /* ── Categories ── */
    .categories { padding: 16px 0 48px; }
    .cat-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: center;
    }
    .cat-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 22px;
      border-radius: 16px;
      background: var(--surface);
      border: 1px solid var(--border);
      font-size: 15px;
      font-weight: 600;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      text-decoration: none;
      color: var(--text);
    }
    .cat-pill:hover {
      border-color: var(--c);
      background: color-mix(in srgb, var(--c) 6%, white);
      transform: translateY(-3px);
      box-shadow: 0 6px 20px color-mix(in srgb, var(--c) 15%, transparent);
    }
    .cat-emoji { font-size: 18px; }
    .cat-count {
      font-size: 12px;
      font-weight: 700;
      color: var(--c);
      background: color-mix(in srgb, var(--c) 10%, transparent);
      padding: 2px 8px;
      border-radius: 999px;
    }

    /* ── CTA ── */
    .cta-section { padding: 0 0 40px; }
    .cta-card {
      position: relative;
      overflow: hidden;
      background: linear-gradient(135deg, rgba(124,58,237,0.06) 0%, rgba(236,72,153,0.05) 50%, rgba(245,158,11,0.04) 100%);
      border: 1px solid rgba(124,58,237,0.1);
      border-radius: 24px;
      padding: 56px 32px;
      text-align: center;
    }
    .cta-glow {
      position: absolute;
      top: 50%; left: 50%;
      width: 300px; height: 300px;
      transform: translate(-50%, -50%);
      background: var(--gradient);
      opacity: 0.06;
      border-radius: 50%;
      filter: blur(60px);
      pointer-events: none;
    }
    .cta-card h2 {
      font-size: 30px;
      font-weight: 800;
      margin-bottom: 8px;
      position: relative;
    }
    .cta-card p { position: relative; }
    .cta-actions {
      position: relative;
      margin-top: 24px;
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }
  </style>

  <script>
    // Sparkle particle canvas — enhanced
    const canvas = document.getElementById('sparkle-canvas') as HTMLCanvasElement;
    if (canvas) {
      const ctx = canvas.getContext('2d');
      type Particle = { x: number; y: number; vx: number; vy: number; size: number; alpha: number; color: string; life: number; maxLife: number; type: 'circle' | 'star' };
      let particles: Particle[] = [];
      const colors = ['#7c3aed', '#ec4899', '#f59e0b', '#a78bfa', '#f472b6', '#c084fc'];

      function resize() {
        canvas.width = canvas.offsetWidth * (window.devicePixelRatio || 1);
        canvas.height = canvas.offsetHeight * (window.devicePixelRatio || 1);
        ctx?.scale(window.devicePixelRatio || 1, window.devicePixelRatio || 1);
      }
      resize();
      window.addEventListener('resize', resize);

      function drawStar(cx: number, cy: number, size: number) {
        if (!ctx) return;
        const spikes = 4;
        const outerRadius = size;
        const innerRadius = size * 0.4;
        ctx.beginPath();
        for (let i = 0; i < spikes * 2; i++) {
          const radius = i % 2 === 0 ? outerRadius : innerRadius;
          const angle = (Math.PI * i) / spikes - Math.PI / 2;
          const x = cx + Math.cos(angle) * radius;
          const y = cy + Math.sin(angle) * radius;
          i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        }
        ctx.closePath();
        ctx.fill();
      }

      function spawnParticle() {
        const maxLife = 100 + Math.random() * 80;
        particles.push({
          x: Math.random() * canvas.offsetWidth,
          y: Math.random() * canvas.offsetHeight,
          vx: (Math.random() - 0.5) * 0.4,
          vy: -0.2 - Math.random() * 0.4,
          size: 1.5 + Math.random() * 3,
          alpha: 0,
          color: colors[Math.floor(Math.random() * colors.length)],
          life: 0,
          maxLife,
          type: Math.random() > 0.6 ? 'star' : 'circle',
        });
      }

      function animate() {
        if (!ctx) return;
        ctx.clearRect(0, 0, canvas.offsetWidth, canvas.offsetHeight);

        if (particles.length < 50 && Math.random() < 0.35) spawnParticle();

        particles = particles.filter((p) => {
          p.life++;
          p.x += p.vx;
          p.y += p.vy;
          const progress = p.life / p.maxLife;
          p.alpha = progress < 0.15 ? progress / 0.15 : progress > 0.65 ? (1 - progress) / 0.35 : 1;
          p.alpha *= 0.7;

          ctx.fillStyle = p.color;
          ctx.globalAlpha = p.alpha;

          if (p.type === 'star') {
            const rotation = p.life * 0.02;
            ctx.save();
            ctx.translate(p.x, p.y);
            ctx.rotate(rotation);
            drawStar(0, 0, p.size);
            ctx.restore();
          } else {
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
            ctx.fill();
          }

          ctx.globalAlpha = 1;
          return p.life < p.maxLife;
        });

        requestAnimationFrame(animate);
      }
      animate();
    }

    // Animated stat counters
    const statNums = document.querySelectorAll('.stat-num[data-target]');
    const statsObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.target || '0');
          let current = 0;
          const duration = 1200;
          const startTime = performance.now();

          function tick(now: number) {
            const elapsed = now - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            current = Math.round(eased * target);
            el.textContent = String(current);
            if (progress < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
          statsObserver.unobserve(el);
        }
      });
    }, { threshold: 0.5 });
    statNums.forEach((el) => statsObserver.observe(el));
  </script>
</BaseLayout>
