---
import BaseLayout from "../../layouts/BaseLayout.astro";
const BASE = import.meta.env.BASE_URL;

const CATEGORIES = ["數學", "物理", "化學", "生物", "資訊", "地科"];

const CATEGORY_ICONS: Record<string, string> = {
  "數學": "📐", "物理": "⚡", "化學": "🧪", "生物": "🧬", "資訊": "💻", "地科": "🌍",
};

const CATEGORY_COLORS: Record<string, string> = {
  "數學": "#7c3aed",
  "物理": "#2563eb",
  "化學": "#dc2626",
  "生物": "#16a34a",
  "資訊": "#0891b2",
  "地科": "#d97706",
};

const allProjects = [
  // 數學 (3)
  { category: "數學", name: "尤耀星", title: "Geometric analysis of the eigenvalue range of the generalized covariance matrix", summary: "In classical random matrix theory, the limiting spectral distribution (LSD) of a sample covariance matrix can be derived explicitly via the Stieltjes transform. However, for generalized sample covariance matrices, no closed-form expression for the LSD is available, complicating efforts to analyze their spectral behavior. In this work, we employ a combination of geometric techniques and the Stieltjes transform to derive rigorous bounds on the support of the eigenvalue distribution for generalized covariance matrices. To assess the sharpness of our theoretical estimates, we conduct numerical simulations under various parameter settings and compare the observed eigenvalue ranges with our predicted bounds. The results demonstrate that our geometric transform approach yields tight approximations to the true spectral edge. These findings offer new insights into the asymptotic behavior of the generalized covariance matrix and provide practical guidelines for applications requiring precise eigenvalue information. In our application, we evaluate image-reconstruction performance by applying an eigenvalue-shrinkage rule to both the proposed generalized sample covariance matrix and the classical sample covariance matrix.", advisor: "王紹宣教授", dept: "國立中央大學統計研究所" },
  { category: "數學", name: "施秉辰", title: "簡單多邊形的可摺性", summary: "本研究探討當給定一簡單多邊形時，是否可以用一張正方形紙經過有限次折疊後使其輪廓與該多邊形相等。", advisor: "", dept: "" },
  { category: "數學", name: "闕子宸", title: "有限次分割操作下整數可構造性之研究", summary: "研究探討在有限次「等分」或「權重分割」下，能否從互質初始重ab中湊出總量1。我們證實了在s等分下，操作步數上界通常為=4n。此外，針對權重分割提出「模運算門檻」作為構造成功的充要條件，揭示了分割操作中的代數不變量。", advisor: "", dept: "" },
  // 物理 (6)
  { category: "物理", name: "王昱閎", title: "矽奈米方塊的光致相變", summary: "", advisor: "朱士維教授、陳致嘉學長、宴德心學長", dept: "國立台灣大學物理系" },
  { category: "物理", name: "吳耘丞", title: "電容放電式電磁彈射器之發射高度與能量效率研究", summary: "本研究利用0.018F電容對線圈瞬間放電，使線圈與下方永久磁鐵產生排斥，帶動線圈與負載向上彈射。測量負載（100、200、400g）與充電電壓（20、40、60V），每組重複5次，量測放電後剩餘電壓與最高高度。結果顯示：100g在60V時平均高度最高，達116.6cm；但平均效率最高出現在100g、20V，為4.61%。整體來看，提高電壓能明顯提升高度，但不一定提高效率。", advisor: "", dept: "" },
  { category: "物理", name: "林煜軒", title: "探究340GHz Radars之測量能力與測量不同牛肉部位之波型", summary: "本研究旨在探討340GHz Radars模組的電磁波傳播特性，分析其測量能力，以及分析並鑑定牛肉不同組織部位。", advisor: "李俊興教授", dept: "國立臺灣大學電機系" },
  { category: "物理", name: "涂皓宇", title: "市場記憶重整化：基於滲流理論的動態 LMF 模型研究", summary: "傳統金融學難以解釋訂單流「長程記憶性」與價格「布朗運動（正常擴散）」共存的悖論。本研究整合 LMF 拆單模型、無標度網絡滲流與平方根價格衝擊定律，建構廣義的市場微觀動力學框架。透過解析推導與大尺度代理人基模型（ABM）模擬，本研究證明：極端羊群效應下的價格發散可被非線性流動性摩擦（凹性衝擊）完美牽制。模型在保留個體異質性下，成功從微觀底層自然湧現出巨觀的穩態價格擴散與長程相關性。", advisor: "陳宣毅教授", dept: "國立中央大學物理系" },
  { category: "物理", name: "黃楷博", title: "利用天文影像進行快速定位", summary: "近年來無人機的定位主要依靠GPS系統進行定位，若訊號被干擾或失聯則會大幅降低準確率。本研究使用python程式語言發展一套定位演算法，並分析定位誤差的可能來源。利用魚眼相機所拍攝的星空影像，找出天頂附近的天球座標系及天頂的座標，結合時間即可算出觀測者所在的經緯度。研究結果顯示減少解析圖片的區域和限制尋找亮度大的天體可減少天求坐標系的誤差，目前最小的誤差約4公里。此方法未來可做為一種低成本的輔助系統，在GPS訊號被干擾的情況下輔助定位。", advisor: "王祥宇教授", dept: "中央研究院天文及物理研究所" },
  { category: "物理", name: "賴敬宇", title: "脈衝熱傳導中 Fourier 失效與 BGK/Callaway 比較", summary: "本研究探討一維脈衝加熱下 Fourier 模型何時失效，並以 Cattaneo 模型描述有限速熱傳；核心控制參數為 δ = ατ/L²。", advisor: "", dept: "" },
  // 化學 (7)
  { category: "化學", name: "杜時晴", title: "雙金屬的第二金屬對CO2還原的影響", summary: "本次實驗中，以Cu為基底固定比例搭配4種不同種類的金屬合成雙金屬觸媒，並比較其對於電催化還原CO₂的氣體產物以及法拉第效率。", advisor: "王禎翰教授", dept: "國立台灣師範大學化學系" },
  { category: "化學", name: "張宸睿", title: "DsKabC蛋白的活性與結構探討", summary: "", advisor: "徐駿森教授 周家誼學長 周俊吉學長", dept: "國立台灣大學農業化學系" },
  { category: "化學", name: "陳柏廷", title: "阿拉伯芥ICE1無序蛋白產生液-液相分離的成因分析", summary: "核定位序列會造成ICE1蛋白聚集於細胞核內，避免了ICE1之342~494片段產生滲出核外的問題。透過植入有不同基因的質體於阿拉伯芥的原生質體中，觀察ICE1蛋白的分布是否位於核內，及其是否有液-液相分離的現象。不論有無植入核定位序列，ICE1的1~341片段所轉錄、轉譯出的蛋白皆位於核內，也都發生了液-液相分離。然而，在342~494片段中，未加入核定位序列的蛋白離奇地離開了細胞核，故透過加入核定位序列，解決了這個問題。", advisor: "楊健志教授、賴佳筠學姐", dept: "國立台灣大學生化科技學系" },
  { category: "化學", name: "詹緯濬", title: "合成新穎酸性 pH 值敏感的 nor-Cy3 螢光分子", summary: "本實驗旨在合成具酸性敏感性的Cy3螢光分子。以4-肼基苯磺酸為起始物，依序經費雪吲哚反應、醯氯化、磺胺化及兩次類醛醇縮合，成功製得Pip-Cy3分子。進一步量測其在不同pH條件下的吸收光譜、螢光光譜與莫爾吸光係數，結果顯示該分子僅在pH低於5.2時呈現明顯螢光。研究不僅建立了有效的合成方法，也顯示其在細胞染色與環境酸鹼感測方面具有潛在應用價值。", advisor: "梁碧惠教授、Fabian Grassl 學長", dept: "國立台灣大學藥學系" },
  { category: "化學", name: "鄧靖懷", title: "胺基改質磷酸化稲殼用於二氧化碳吸附之研究", summary: "因應全球二氧化碳捕集與減排需求，本研究以稻殼（Rice Husk, RH）為基底，製備一系列吸附材料，探討其吸附CO₂的性能。製備的高溫活化活性碳（RHPAC）與胺基處理RHPMy系列（y=0.5,1,2,3），為確認其結構，進行了多種表徵分析。吸附實驗中設計了多種變因，包括材料、CO₂濃度、流量、選擇性，並評估其吸附效率。RHPM1在貫穿曲線上展現最高CO₂吸附容量，且高濃度、低流量下呈現較高吸附效率。可知本材料不失為一具潛力的綠色固體吸附劑。", advisor: "吳紀勝教授，李思偉，黃韻心學姐", dept: "國立台灣大學化工系" },
  { category: "化學", name: "蕭敬庭", title: "TiO₂降解亞甲藍的不同電子接收劑探討", summary: "本研究以二氧化鈦懸浮液在紫外光照下進行亞甲基藍（MB）的光催化降解反應，探討加入不同濃度的電子接收劑（硝酸銅、硝酸鐵）對降解反應速率的影響。", advisor: "王建隆教授、鄭振谷學長", dept: "國立台灣大學化學系" },
  { category: "化學", name: "顏廷翰", title: "基於自組裝 DNA 四面體和 HCR 反應的 miR-124-3p 檢測", summary: "微核醣核酸 (microRNA) 的表現水平可作為許多疾病的早期診斷指標。本研究設計出四條 DNA 序列，可透過鹼基互補，自組裝成 DNA 四面體。其上的髮夾探針遇到 miR-124-3p 會啟動 H1、H2 的鏈式雜合反應 (Hybridization Chain Reaction, HCR)，進而擴增訊號。", advisor: "何佳安教授 吳毓凌學姐 蔡沁彤學姐 湯鈺惠學姐", dept: "國立台灣大學生化科技學系" },
  // 生物 (6)
  { category: "生物", name: "吳祉樂", title: "探討NAT10蛋白與端粒酶活性之互動與關聯", summary: "端粒酶透過 TERC 維持端粒長度，確保基因體穩定。分析過往研究發現，RNA 乙醯轉移酶 NAT10 可在 TERC 上進行 ac4C 修飾，增強其穩定性並促進端粒酶活性。NAT10 缺失會導致細胞增殖下降、端粒酶功能受損及端粒縮短，而 telomerase 基因表現未受影響。結果顯示 NAT10 為端粒酶的正向調控因子，揭示 RNA 修飾與端粒維持間的重要關聯。", advisor: "朱雪萍教授 楊育昇學長", dept: "國立台灣大學分子與細胞生物學研究所" },
  { category: "生物", name: "邱懷賦", title: "XCP1蛋白質的結構探討", summary: "本研究以植物木質部特異性半胱胺酸蛋白酶XCP1為研究標的，目標是透過E. coli大量表現以純化，並以X光繞射解析其三維結構。XCP1可辨識並切割PR1蛋白，釋放訊號肽CAPE9，可調控SA主導之系統性免疫反應，在植物防禦中具重要意義。", advisor: "徐駿森教授 簡弈崴學長 郭伯彥學長", dept: "國立台灣大學農業化學系" },
  { category: "生物", name: "張庭溱", title: "探討腦瘤治療藥物的優化", summary: "本研究探討多種腦瘤藥物與多種H-Ferritin修飾物的藥物封裝，藉此增加傳統藥物治療的靶向性以及封裝率，而本研究與相關研究整體上旨在提高腦瘤藥物治療的效能及經濟性。", advisor: "黃楓婷教授 張虔翊學長 張筠廷學姐", dept: "國立台灣大學生化科技學系" },
  { category: "生物", name: "張瑛太", title: "不同植物族群APX酶對GSH的結合能力比較與演化趨勢分析", summary: "本研究探討植物抗壞血酸過氧化物酶（APX）對穀胱甘肽（GSH）結合能力的演化。選取涵蓋蘚苔至被子植物等9種模式物種，利用MEGA 12構建親緣樹並以AlphaFold 3預測結構。經PyMOL疊合分析，所有物種APX結構高度重疊，RMSD值均小於0.4，且三個GSH關鍵活性位點空間分佈極為一致。結果證實APX結合位點具有極高演化保守性，是植物適應陸地逆境、維持生理穩定的關鍵機制。", advisor: "鄭貽生教授、林楷鈞學長", dept: "國立台灣大學生命科學系" },
  { category: "生物", name: "黃品鈞", title: "探討 IDOL 在 T 細胞活化與功能上扮演的角色", summary: "本研究探討IDOL在T細胞活化與功能中扮演的角色。膽固醇的代謝與T細胞的活化具有高相關性，而參與其調控的IDOL蛋白，是值得研究的對象。因此我們利用癌化T細胞Jurkat細胞株，透過活化後觀察IDOL的表現量，以及改變IDOL的表達量，分析其對膽固醇基因表達及細胞激素的影響。初步的研究顯示，活化後的T細胞其IDOL表現量有上升趨勢。進一步使用CRISPR-Cas9技術剔除IDOL基因，結果顯示剔除IDOL後，T細胞的部分細胞激素表達量明顯上升，成為IDOL與T細胞活化相關的有力證據。", advisor: "柯俊榮教授、莊煒婷學姐", dept: "國立台灣大學醫學院免疫所" },
  { category: "生物", name: "蘇冠宇", title: "篩選微生物具廣效性抗黴菌真菌之能力及其活性物質之分析", summary: "本研究從土壤採集開始，進行篩菌、養菌與抗菌測試，欲從其中找出具有抗黴菌、真菌效果之菌株。本研究總共採集了九個地點的土壤樣本，並篩選出約 150 個菌株。在初步測試中，找到了 24 種具有抗菌效果。在後續的測試中，有 3 種在抑制白色念珠菌的生長上具有極為良好的效果。等待未來進行進一步的測試", advisor: "黃志宏教授", dept: "國立台北科技大學化學工程與生物科技系" },
  // 地科 (1)
  { category: "地科", name: "周紘宇", title: "以氧同位素重建古代溫躍層結構", summary: "", advisor: "羅立教授、楊峻誌學長", dept: "國立台灣大學地質系" },
  // 資訊 (6)
  { category: "資訊", name: "李牧寬", title: "以 SLEUTH 模型探討交通、地形與政策對都市擴張的影響，以臺北都會區為例", summary: "本研究藉由SLEUTH細胞自動機模型，探討臺北都會區之交通、地形與政策對都市擴張的影響。實驗結果顯示，地形是限制都市面積擴張並促使都市形狀趨於緊湊與規則化的主因；政策管制則能有效抑制都市聚落過度融合，並對減緩都市擴張具有實質成效。此外，捷運路網的興建降低總體都市面積，並使都市邊緣規則化發展。", advisor: "", dept: "" },
  { category: "資訊", name: "林秉坤", title: "DQN 遷移學習效益研究-以貪吃蛇為例", summary: "", advisor: "戴文凱教授", dept: "國立臺灣科技大學資訊工程系" },
  { category: "資訊", name: "崔恩睿、曾宣澂", title: "應用不同強化學習方法訓練「皮卡丘打排球」之比較和分析", summary: "", advisor: "戴文凱教授", dept: "國立臺灣科技大學資訊工程系" },
  { category: "資訊", name: "彭耀霆", title: "基於頻域紋理特徵的寫實圖像隱寫系統", summary: "", advisor: "", dept: "" },
  { category: "資訊", name: "楊翊程", title: "以 Super Mario 為例探討強化學習的卡關問題與改進方法", summary: "本研究探討 Super Mario 強化學習模型的卡關問題，並結合區域探索與經驗回放加權，讓模型更集中學習關鍵失敗位置。結果顯示，此方法比單純增加整體探索更有效，能提升突破能力與訓練效率。", advisor: "陳尚澤教授", dept: "國立臺灣科技大學資訊工程系" },
  { category: "資訊", name: "藍翊庭", title: "基於 WGAN-GP 的字體風格遷移研究", summary: "為解決中文字體生成問題，本研究提出一套基於WGAN-GP的少樣本字體風格遷移架構，克服傳統GAN的不穩定性等問題。核心發現有三：首先，證實同步變換增強能有效利用漢字部件重複之特性，提升模型泛化能力。其次，針對瓶頸層尺寸之變因，透過t-SNE與線性探針實驗進行系統性分析，得出4×4與8×8為最佳尺寸。最後，發現此架構之Wasserstein距離能對幾何結構提供穩定梯度指引，允許我們移除易造成模糊的L1像素損失，生成結構精準且更為銳利的圖像。最終將架構套用至中文字體，取得理想效果。", advisor: "", dept: "" },
];
---

<BaseLayout title="專題總覽｜Sparkle">
  <section class="page-header fade-up">
    <h1 class="section-title">專題總覽</h1>
    <p class="section-sub">瀏覽 {allProjects.length} 個跨領域研究專題</p>
  </section>

  <!-- Search bar -->
  <div class="search-bar fade-up">
    <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" id="search-input" placeholder="搜尋專題名稱、作者或指導教授…" autocomplete="off" />
    <span class="search-count" id="search-count"></span>
  </div>

  <!-- Category filters (JS-driven) -->
  <div class="filters fade-up" id="filters">
    <button class="filter-chip active" data-cat="全部">
      全部 <span class="chip-count">{allProjects.length}</span>
    </button>
    {CATEGORIES.map((cat) => {
      const count = allProjects.filter((p) => p.category === cat).length;
      return (
        <button class="filter-chip" data-cat={cat}>
          <span class="chip-icon">{CATEGORY_ICONS[cat]}</span>
          {cat}
          <span class="chip-count">{count}</span>
        </button>
      );
    })}
  </div>

  <div class="project-grid" id="project-grid">
    {allProjects.map((p, idx) => (
      <div class="project-card fade-up" data-category={p.category} style={`--i:${idx % 6}; --cat-color: ${CATEGORY_COLORS[p.category]}`}>
        <div class="project-cat-badge" style={`background: ${CATEGORY_COLORS[p.category]}15; color: ${CATEGORY_COLORS[p.category]}`}>
          {CATEGORY_ICONS[p.category]} {p.category}
        </div>
        <h3 class="project-title">{p.title || "（題目待定）"}</h3>
        <div class="project-meta">
          <span class="project-name">{p.name}</span>
          {p.advisor && <span class="project-advisor">{p.advisor}</span>}
          {p.dept && <span class="project-dept">{p.dept}</span>}
        </div>
        {p.summary && (
          <div class="summary-wrap">
            <p class="project-summary muted">{p.summary}</p>
            <button class="summary-toggle">展開</button>
          </div>
        )}
      </div>
    ))}
  </div>

  <div class="empty-state" id="empty-state" style="display:none;">
    <div class="empty-icon">📭</div>
    <p>此分類暫無專題</p>
  </div>

  <style>
    .page-header { padding: 20px 0 8px; }

    /* ── Search bar ── */
    .search-bar {
      position: relative;
      margin-bottom: 16px;
    }
    .search-bar input {
      width: 100%;
      padding: 14px 16px 14px 44px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--surface);
      font-size: 15px;
      font-family: inherit;
      color: var(--text);
      transition: all var(--transition);
      outline: none;
    }
    .search-bar input:focus {
      border-color: var(--accent-light);
      box-shadow: 0 0 0 3px rgba(124,58,237,0.1);
    }
    .search-bar input::placeholder { color: var(--muted); }
    .search-icon {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
      pointer-events: none;
    }
    .search-count {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 13px;
      font-weight: 600;
      color: var(--muted);
    }

    .filters {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 28px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border);
    }

    .filter-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--surface);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: all var(--transition);
      font-family: inherit;
      color: var(--text);
    }
    .filter-chip:hover {
      border-color: var(--accent-light);
      background: var(--accent-bg);
    }
    .filter-chip.active {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
    }
    .filter-chip.active .chip-count {
      background: rgba(255,255,255,0.25);
      color: #fff;
    }
    .chip-icon { font-size: 15px; }
    .chip-count {
      font-size: 12px;
      background: var(--border);
      padding: 1px 7px;
      border-radius: 999px;
      font-weight: 600;
    }

    .project-grid {
      display: grid;
      gap: 16px;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    }

    .project-card {
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 24px;
      background: var(--surface);
      transition: all var(--transition);
      position: relative;
      overflow: hidden;
    }
    .project-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: var(--cat-color);
      opacity: 0.3;
      transition: opacity var(--transition);
    }
    .project-card:hover {
      border-color: rgba(124,58,237,0.15);
      box-shadow: var(--shadow);
      transform: translateY(-2px);
    }
    .project-card:hover::before { opacity: 1; }

    .project-card.hiding {
      opacity: 0;
      transform: scale(0.95);
      pointer-events: none;
      position: absolute;
      visibility: hidden;
    }

    .project-cat-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 12px;
      font-weight: 600;
      padding: 4px 10px;
      border-radius: 999px;
      margin-bottom: 12px;
    }
    .project-title {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 6px;
      line-height: 1.4;
    }
    .project-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 8px;
    }
    .project-name {
      font-size: 13px;
      font-weight: 600;
      color: var(--accent);
      background: var(--accent-bg);
      padding: 2px 10px;
      border-radius: 6px;
    }
    .project-advisor, .project-dept {
      font-size: 12px;
      color: var(--muted);
      background: var(--border);
      padding: 2px 8px;
      border-radius: 6px;
    }
    .project-summary {
      font-size: 14px;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .project-summary.expanded {
      -webkit-line-clamp: unset;
    }
    .summary-toggle {
      display: inline;
      font-size: 12px;
      font-weight: 600;
      color: var(--accent);
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
      margin-top: 4px;
      font-family: inherit;
    }
    .summary-toggle:hover { text-decoration: underline; }

    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: var(--muted);
    }
    .empty-icon { font-size: 40px; margin-bottom: 12px; }

    @media (max-width: 520px) {
      .project-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    const chips = document.querySelectorAll('.filter-chip');
    const cards = document.querySelectorAll('.project-card') as NodeListOf<HTMLElement>;
    const emptyState = document.getElementById('empty-state');
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const searchCount = document.getElementById('search-count');

    function filterCards() {
      const activeChip = document.querySelector('.filter-chip.active');
      const cat = activeChip?.getAttribute('data-cat') || '全部';
      const query = (searchInput?.value || '').toLowerCase().trim();
      let visibleCount = 0;

      cards.forEach((card) => {
        const catMatch = cat === '全部' || card.getAttribute('data-category') === cat;
        const text = card.textContent?.toLowerCase() || '';
        const searchMatch = !query || text.includes(query);
        const match = catMatch && searchMatch;
        card.classList.toggle('hiding', !match);
        if (match) visibleCount++;
      });

      if (emptyState) emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
      if (searchCount) searchCount.textContent = query ? `${visibleCount} 筆結果` : '';
    }

    searchInput?.addEventListener('input', filterCards);

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => c.classList.remove('active'));
        chip.classList.add('active');
        filterCards();
      });
    });

    // URL param pre-selection (?cat=數學)
    const urlParams = new URLSearchParams(window.location.search);
    const initialCat = urlParams.get('cat');
    if (initialCat) {
      chips.forEach((c) => {
        const isMatch = c.getAttribute('data-cat') === initialCat;
        c.classList.toggle('active', isMatch);
      });
      filterCards();
    }

    // Summary expand/collapse
    document.querySelectorAll('.summary-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const p = btn.previousElementSibling as HTMLElement;
        const expanded = p.classList.toggle('expanded');
        btn.textContent = expanded ? '收合' : '展開';
      });
    });
  </script>
</BaseLayout>
