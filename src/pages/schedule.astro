---
import BaseLayout from "../layouts/BaseLayout.astro";

const info = [
  { icon: "📍", label: "地點", value: "建國中學夢紅樓" },
  { icon: "📅", label: "日期", value: "2026 年 5 月 18 日（週一）" },
  { icon: "🕐", label: "時間", value: "中午 12:30 開始" },
  { icon: "🚌", label: "交通", value: "捷運中正紀念堂站" },
];

const timeline = [
  { time: "12:30 – 13:00", activity: "報到", location: "一樓大廳", icon: "📋" },
  { time: "13:00 – 13:30", activity: "開場、致辭、影片（一）", location: "二樓展演廳", icon: "🎤" },
  { time: "13:30 – 13:40", activity: "移動至各分組場地", location: "", icon: "🚶" },
  { time: "13:40 – 14:50", activity: "分組報告上半場", location: "二樓展演廳 / 四樓國際會議廳", icon: "📊" },
  { time: "14:50 – 15:30", activity: "中場休息、參觀展板", location: "一樓藝廊和二樓走廊", icon: "☕" },
  { time: "15:30 – 16:50", activity: "影片（二）、分組報告下半場", location: "二樓展演廳 / 四樓國際會議廳", icon: "🔬" },
  { time: "16:50 – 17:00", activity: "移動至二樓展演廳", location: "", icon: "🚶" },
  { time: "17:00 – 17:30", activity: "影片（三）、閉幕儀式", location: "二樓展演廳", icon: "🎬" },
];

const venue4F = {
  name: "夢紅樓四樓國際會議廳",
  sessions: [
    { time: "13:40 – 13:50", name: "張瑛太", category: "生物", topic: "不同植物族群 APX 酶對 GSH 的結合能力比較與演化趨勢分析", advisor: "鄭貽生教授、黃慧茹老師" },
    { time: "13:50 – 14:00", name: "吳祉樂", category: "生物", topic: "探討 NAT10 蛋白與端粒酶活性之互動與關聯", advisor: "朱雪萍教授、黃慧茹老師" },
    { time: "14:00 – 14:10", name: "張庭溱", category: "生物", topic: "探討腦瘤治療藥物的優化", advisor: "黃楓婷教授、黃慧茹老師" },
    { time: "14:10 – 14:20", name: "蘇冠宇", category: "生物", topic: "篩選微生物具廣效性抗黴菌真菌之能力及其活性物質之分析", advisor: "黃志宏教授、黃慧茹老師" },
    { time: "14:20 – 14:30", name: "邱懷賦", category: "生物", topic: "XCP1 蛋白質的結構探討", advisor: "徐駿森教授、黃慧茹老師" },
    { time: "14:30 – 14:40", name: "黃品鈞", category: "生物", topic: "探討 IDOL 在 T 細胞活化與功能上扮演的角色", advisor: "柯俊榮教授、黃慧茹老師" },
    { time: "14:40 – 14:50", name: "施秉辰", category: "數學", topic: "簡單多邊形的可摺性", advisor: "侯以修老師" },
    { time: "break", name: "", category: "", topic: "中場休息、參觀展版", advisor: "" },
    { time: "15:30 – 15:40", name: "尤耀星", category: "數學", topic: "Geometric analysis of the eigenvalue range of the generalized covariance matrix", advisor: "王紹宣教授、侯以修老師" },
    { time: "15:40 – 15:50", name: "闕子宸", category: "數學", topic: "有限次分割操作下整數可構造性之研究", advisor: "侯以修老師" },
    { time: "15:50 – 16:00", name: "林煜軒", category: "物理", topic: "探究340GHz Radars之測量能力與測量不同牛肉部位之波型", advisor: "李俊興教授、林元祥老師" },
    { time: "16:00 – 16:10", name: "黃楷博", category: "物理", topic: "利用天文影像進行快速定位", advisor: "王祥宇教授、林元祥老師" },
    { time: "16:10 – 16:20", name: "王昱閎", category: "物理", topic: "矽奈米方塊的光致相變", advisor: "朱士維教授、林元祥老師" },
    { time: "16:20 – 16:30", name: "涂皓宇", category: "物理", topic: "流動性撤除下的 LMF-Hawkes 失衡標度模型", advisor: "陳宣毅教授、林元祥老師" },
    { time: "16:30 – 16:40", name: "吳耘丞", category: "物理", topic: "電容放電式電磁彈射器之發射高度與能量效率研究", advisor: "林元祥老師" },
    { time: "16:40 – 16:50", name: "賴敬宇", category: "物理", topic: "脈衝熱傳導中 Fourier 失效與 BGK/Callaway 比較", advisor: "林元祥老師" },
  ],
};

const venue2F = {
  name: "夢紅樓二樓展演廳",
  sessions: [
    { time: "13:40 – 13:50", name: "周紘宇", category: "地科", topic: "以有孔蟲氧同位素重建古代溫躍層", advisor: "羅立教授、李文禮老師" },
    { time: "13:50 – 14:00", name: "崔恩睿、曾宣澂", category: "資訊", topic: "強化學習在動態對抗環境中的策略適應性研究：以皮卡丘打排球為例", advisor: "戴文凱教授、劉新韋老師" },
    { time: "14:00 – 14:10", name: "林秉坤", category: "資訊", topic: "二維 Ising 模型中有限長缺陷段的 KZM 端點標度", advisor: "戴文凱教授、劉新韋老師" },
    { time: "14:10 – 14:20", name: "藍翊庭", category: "資訊", topic: "基於 WGAN-GP 的字體風格遷移研究", advisor: "劉新韋老師" },
    { time: "14:20 – 14:30", name: "李牧寬", category: "資訊", topic: "以 SLEUTH 模型探討交通、地形與政策對都市擴張的影響，以臺北都會區為例", advisor: "劉新韋老師" },
    { time: "14:30 – 14:40", name: "楊翊程", category: "資訊", topic: "以 Super Mario 為例探討強化學習的卡關問題與改進方法", advisor: "陳尚澤教授、劉新韋老師" },
    { time: "14:40 – 14:50", name: "彭耀霆", category: "資訊", topic: "基於頻域紋理特徵的寫實圖像隱寫系統", advisor: "劉新韋老師" },
    { time: "break", name: "", category: "", topic: "中場休息、參觀展版", advisor: "" },
    { time: "15:30 – 15:40", name: "詹緯濬", category: "化學", topic: "合成新穎酸性 pH 值敏感的 nor-Cy3 螢光分子", advisor: "梁碧惠教授、廖家榮老師" },
    { time: "15:40 – 15:50", name: "杜時晴", category: "化學", topic: "雙金屬的第二金屬對 CO2 還原的影響", advisor: "王禎翰教授、廖家榮老師" },
    { time: "15:50 – 16:00", name: "鄧靖懷", category: "化學", topic: "胺基改質磷酸化稻殼用於二氧化碳吸附之研究", advisor: "吳紀勝教授、廖家榮老師" },
    { time: "16:00 – 16:10", name: "陳柏廷", category: "化學", topic: "阿拉伯芥 ICE1 無序蛋白產生液-液相分離的成因分析", advisor: "楊健志教授、廖家榮老師" },
    { time: "16:10 – 16:20", name: "蕭敬庭", category: "化學", topic: "TiO₂ 降解亞甲藍的不同電子接收劑探討", advisor: "王建隆教授、廖家榮老師" },
    { time: "16:20 – 16:30", name: "顏廷翰", category: "化學", topic: "基於自組裝 DNA 四面體和 HCR 反應的 miR-124-3p 檢測", advisor: "何佳安教授、廖家榮老師" },
    { time: "16:30 – 16:40", name: "張宸睿", category: "化學", topic: "DsKabC 蛋白的活性與結構探討", advisor: "徐駿森教授、廖家榮老師" },
  ],
};

const categoryColors: Record<string, string> = {
  "數學": "#6366f1",
  "物理": "#f59e0b",
  "化學": "#10b981",
  "生物": "#ec4899",
  "地科": "#8b5cf6",
  "資訊": "#3b82f6",
};
---

<BaseLayout title="流程與交通｜Sparkle">
  <section class="page-header fade-up">
    <h1 class="section-title">議程表</h1>
    <p class="section-sub">專題發表時間、場地與報告順序</p>
  </section>

  <!-- Info cards -->
  <div class="info-grid fade-up">
    {info.map((item) => (
      <div class="info-card">
        <span class="info-icon">{item.icon}</span>
        <div>
          <div class="info-label">{item.label}</div>
          <div class="info-value">{item.value}</div>
        </div>
      </div>
    ))}
  </div>

  <!-- Overall Timeline -->
  <section class="timeline-section fade-up">
    <div class="timeline-header">
      <span class="venue-icon">📅</span>
      <h2 class="venue-title">活動流程</h2>
    </div>
    <div class="timeline">
      {timeline.map((item, idx) => (
        <div class="timeline-item">
          <div class="timeline-dot-wrap">
            <div class="timeline-dot">{item.icon}</div>
            {idx < timeline.length - 1 && <div class="timeline-line" />}
          </div>
          <div class="timeline-content">
            <div class="timeline-time">{item.time}</div>
            <h3 class="timeline-title">{item.activity}</h3>
            {item.location && <p class="timeline-loc muted">{item.location}</p>}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Venue 4F -->
  <section class="venue-section fade-up">
    <div class="venue-header">
      <span class="venue-icon">🏛️</span>
      <h2 class="venue-title">{venue4F.name}</h2>
    </div>
    <div class="schedule-table-wrap">
      <table class="schedule-table">
        <thead>
          <tr>
            <th class="col-time">時間</th>
            <th class="col-name">姓名</th>
            <th class="col-cat">組別</th>
            <th class="col-topic">專題名稱</th>
            <th class="col-advisor">指導教授 / 老師</th>
          </tr>
        </thead>
        <tbody>
          {venue4F.sessions.map((s) =>
            s.time === "break" ? (
              <tr class="break-row">
                <td colspan="5">
                  <div class="break-label">☕ {s.topic}</div>
                </td>
              </tr>
            ) : (
              <tr>
                <td class="cell-time">{s.time}</td>
                <td class="cell-name">{s.name}</td>
                <td>
                  <span class="cat-badge" style={`--cat-color: ${categoryColors[s.category] || '#6b7280'}`}>
                    {s.category}
                  </span>
                </td>
                <td class="cell-topic">{s.topic || "—"}</td>
                <td class="cell-advisor">{s.advisor}</td>
              </tr>
            )
          )}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Venue 2F -->
  <section class="venue-section fade-up">
    <div class="venue-header">
      <span class="venue-icon">🎭</span>
      <h2 class="venue-title">{venue2F.name}</h2>
    </div>
    <div class="schedule-table-wrap">
      <table class="schedule-table">
        <thead>
          <tr>
            <th class="col-time">時間</th>
            <th class="col-name">姓名</th>
            <th class="col-cat">組別</th>
            <th class="col-topic">專題名稱</th>
            <th class="col-advisor">指導教授 / 老師</th>
          </tr>
        </thead>
        <tbody>
          {venue2F.sessions.map((s) =>
            s.time === "break" ? (
              <tr class="break-row">
                <td colspan="5">
                  <div class="break-label">☕ {s.topic}</div>
                </td>
              </tr>
            ) : (
              <tr>
                <td class="cell-time">{s.time}</td>
                <td class="cell-name">{s.name}</td>
                <td>
                  <span class="cat-badge" style={`--cat-color: ${categoryColors[s.category] || '#6b7280'}`}>
                    {s.category}
                  </span>
                </td>
                <td class="cell-topic">{s.topic || "—"}</td>
                <td class="cell-advisor">{s.advisor}</td>
              </tr>
            )
          )}
        </tbody>
      </table>
    </div>
  </section>

  <style>
    .page-header { padding: 20px 0 8px; }

    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 12px;
      margin-bottom: 40px;
    }
    .info-card {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 18px 20px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      background: var(--surface);
      transition: all var(--transition);
    }
    .info-card:hover {
      box-shadow: var(--shadow-sm);
      border-color: rgba(124,58,237,0.15);
    }
    .info-icon {
      font-size: 24px;
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 12px;
      background: var(--gradient-subtle);
      flex-shrink: 0;
    }
    .info-label { font-size: 12px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
    .info-value { font-size: 15px; font-weight: 600; margin-top: 2px; }

    /* Timeline */
    .timeline-section { margin-bottom: 48px; }
    .timeline-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }
    .timeline { margin-top: 8px; }
    .timeline-item {
      display: flex;
      gap: 20px;
      position: relative;
    }
    .timeline-dot-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      flex-shrink: 0;
      width: 48px;
    }
    .timeline-dot {
      width: 48px;
      height: 48px;
      border-radius: 14px;
      background: var(--surface);
      border: 2px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      flex-shrink: 0;
      z-index: 1;
      transition: all var(--transition);
    }
    .timeline-item:hover .timeline-dot {
      border-color: var(--accent-light);
      box-shadow: 0 0 0 4px rgba(124,58,237,0.08);
    }
    .timeline-line {
      width: 2px;
      flex: 1;
      min-height: 20px;
      background: var(--border);
    }
    .timeline-content { padding: 10px 0 28px; }
    .timeline-time {
      font-size: 13px;
      font-weight: 600;
      color: var(--accent);
      margin-bottom: 4px;
    }
    .timeline-title { font-size: 16px; font-weight: 700; margin-bottom: 2px; }
    .timeline-loc { font-size: 13px; }

    @media (max-width: 520px) {
      .timeline-dot-wrap { width: 40px; }
      .timeline-dot { width: 40px; height: 40px; font-size: 18px; }
    }

    /* Venue */
    .venue-section {
      margin-bottom: 48px;
    }
    .venue-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }
    .venue-icon {
      font-size: 28px;
    }
    .venue-title {
      font-size: 22px;
      font-weight: 700;
    }

    /* Table */
    .schedule-table-wrap {
      overflow-x: auto;
      border-radius: var(--radius);
      border: 1px solid var(--border);
    }
    .schedule-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    .schedule-table thead {
      background: var(--gradient-subtle);
    }
    .schedule-table th {
      padding: 12px 14px;
      text-align: left;
      font-size: 13px;
      font-weight: 600;
      color: var(--muted);
      white-space: nowrap;
      border-bottom: 2px solid var(--border);
    }
    .schedule-table td {
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }
    .schedule-table tbody tr:last-child td {
      border-bottom: none;
    }
    .schedule-table tbody tr:hover {
      background: var(--accent-bg);
    }

    .col-time { width: 120px; }
    .col-name { width: 100px; }
    .col-cat { width: 60px; }
    .col-advisor { width: 160px; }

    .cell-time {
      font-weight: 600;
      font-size: 13px;
      color: var(--accent);
      white-space: nowrap;
    }
    .cell-name {
      font-weight: 600;
      white-space: nowrap;
    }
    .cell-topic {
      line-height: 1.5;
    }
    .cell-advisor {
      font-size: 13px;
      color: var(--muted);
    }

    .cat-badge {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
      color: var(--cat-color);
      background: color-mix(in srgb, var(--cat-color) 10%, transparent);
      white-space: nowrap;
    }

    .break-row td {
      padding: 0;
      border-bottom: 1px solid var(--border);
    }
    .break-label {
      text-align: center;
      padding: 18px;
      font-weight: 600;
      font-size: 14px;
      color: var(--accent);
      background: var(--gradient-subtle);
      border-top: 2px dashed rgba(124,58,237,0.15);
      border-bottom: 2px dashed rgba(124,58,237,0.15);
    }

    @media (max-width: 768px) {
      .schedule-table {
        font-size: 13px;
      }
      .schedule-table th,
      .schedule-table td {
        padding: 8px 10px;
      }
      .col-advisor {
        display: none;
      }
      .schedule-table th:last-child {
        display: none;
      }
    }

    @media (max-width: 520px) {
      .schedule-table thead { display: none; }
      .schedule-table tbody tr:not(.break-row) {
        display: flex;
        flex-wrap: wrap;
        padding: 14px;
        gap: 6px;
        border-bottom: 1px solid var(--border);
      }
      .schedule-table tbody tr:not(.break-row) td {
        border-bottom: none;
        padding: 0;
      }
      .cell-time { font-size: 12px; width: auto; order: 1; }
      .cell-name { order: 2; margin-left: auto; }
      .schedule-table tbody tr:not(.break-row) td:nth-child(3) { order: 3; }
      .cell-topic { order: 4; width: 100%; font-size: 14px; margin-top: 4px; font-weight: 600; }
      .cell-advisor { order: 5; width: 100%; display: block !important; font-size: 12px; }
    }
  </style>
</BaseLayout>
