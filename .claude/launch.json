{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "astro-dev",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/astro/astro.js", "dev"],
      "port": 4321
    },
    {
      "name": "static",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path');const m={'html':'text/html','css':'text/css','js':'application/javascript','svg':'image/svg+xml','ico':'image/x-icon','json':'application/json'};h.createServer((q,r)=>{let u=q.url.split('?')[0];if(u.endsWith('/'))u+='index.html';const ext=p.extname(u).slice(1);const fp=p.join('docs',u);f.readFile(fp,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');return}r.writeHead(200,{'Content-Type':m[ext]||'application/octet-stream'});r.end(d)})}).listen(3000,()=>console.log('Static server on http://localhost:3000'))"],
      "port": 3000
    }
  ]
}
